---
config:
  layout: elk
---
classDiagram
direction TB
    class Giocatore {
	    -fame : int
	    -mente : int
	    +Giocatore(nome : String, path : String)
	    +attacca()
	    +utilizzaAbilita()*
	    +utilizzaOggetto(ogg : Oggetto)
	    +muovi()
	    +controllaMorte() boolean
	    +perdiMente(perdita : int)
	    +guadagnaMente(guadagno : int)
	    +perdiFame(perdita : int)
	    +guadagnaFame(guadagno : int)
	    +setOggetto(oggetto : OggettoEquipaggiabile)
	    +getOggettoDifensivo() OggettoEquipaggiabile
	    +getOggettoOffensivo() OggettoEquipaggiabile
	    +consumaOggetto(oggetto : OggettoConsumabile)
    }

    class Party {
	    +aggiungiMembro(giocabile : Giocabile)
	    +rimuoviMembro(giocabile : Giocabile)
	    +getParty() ArrayList~Giocabile~
	    +getGiocatori() ArrayList~Giocatore~
	    +getOggettiConsumabili() ArrayList~OggettoConsumabile~
	    +getOggettiEquipaggiabili() ArrayList~OggettoEquipaggiabile~
	    +cambiaOggetto(giocatore : Giocatore, oggetto : OggettoEquipaggiabile)
	    +usaOggetto(giocatore : Giocatore, oggetto : OggettoConsumabile)
	    +aggiungiOggetto(oggetto : OggettoConsumabile)
	    +aggiungiOggetto(oggetto : OggettoEquipaggiabile)
    }

	class Inventario{
		+aggiungiOggetto(oggetto : Oggetto)
	    +togliOggetto(oggetto : Oggetto)
		+getOggettiEquipaggiabili() ArrayList~OggettoEquipaggiabile~
		+getOggettiConsumabili() ArrayList~OggettoConsumabile~
	}

    class Mercenario {
	    +utilizzaAbilita()
    }

    class Cavaliere {
	    +utilizzaAbilita()
    }

    class Necromante {
	    +utilizzaAbilita()
    }

    class Vichingo {
	    +utilizzaAbilita()
    }

    class Girl {
	    +utilizzaAbilita()
    }

    class Moonless {
	    +utilizzaAbilita()
    }

    class Demonchild {
	    +utilizzaAbilita()
    }

	class Oggetto{
		-nome : String
		-sprite : ImageIcon
		+getNome() String
	    +getSprite() ImageIcon
		+Oggetto(nome : String, path : String)
	}
	
    class OggettoEquipaggiabile {        
        -agilita : int
        -tipo : TipoOggettoEquipaggiabile    
		-statPrincipale : int
        +OggettoEquipaggiabile(nome : String, path : String, statprincipale : int, agilita : int, tipo :TipoOgettoEquipaggiabile)
        +getStatPrincipale() int 
        +getAgilita() int 
        +getTipo() TipoOggettoEquipaggiabile
    }

    class OggettoConsumabile {
        -statPrincipale : int 
        -tipo : TipoOggettoConsumabile
        +OggettoConsumabile(nome : String, path : String, statprincipale : int, tipo : TipoOggettoConsumabile)
        +getStatPrincipale() int 
        +getTipo() TipoOggettoConsumabile
    }

    class TipoOggettoEquipaggiabile {
	    DIFENSIVO
	    OFFENSIVO
    }

    class TipoOggettoConsumabile {
	    COMMESTIBILE
	    CURATIVO
	    MENTALE
    }

    class Nemico {
    }

    class GestoreGioco {
	    -posizione : int[]
	    -tipoCella : TipoCella
	    +GestoreGioco()
		+inizializza(leader : Giocatore, logger : Logger)
	    +muovi(movX : int, movY : int)
	    +interazioneCreabile()
	    +iniziaCombattimento()
	    +apriInventario()
	    +trovaOggetto()
	    +trovaAlleato()
	    +finePartita()
    }

    class Mappa {
	    -righe : int
	    -numCella : int
	    +Mappa(righe : int)
	    +getGriglia(bordo : boolean) Cella[][]
	    +aggiungiCella(cella : Cella)
	    +aggiungiCella(cella : Cella, x : int, y : int)
	    +getIdCreabileCella(x : int, y : int) String 
		+getStatoCella(int x, int y) int
	    +setStatoCella(stato : int, x : int, y : int)
    }

    class Cella {
	    +VISITATA : int
	    +NON_VISITATA : int
	    +COMPLETATA : int
	    -tipo : int
	    -idCreabile : String
	    -stato : int
	    +getIdCrebile() String
		+getStato() int
	    +setStato(stato : int)
    }

    class GestoreInput {
    }

    class GestoreCombattimento {
	    +iniziaCombattimento(party : Party, nemico : Nemico)
	    +calcolaAttacco() int
    }

    class TipoCella {
	    VUOTO
	    MURO
	    PIENO
	    FINE
	    INIZIO
    }

    class GeneratoreMappa {
	    -grandezzaMappa : int$
		-rnd : Random
		-idSet : Integer[]
	    +generaMappa(g : GestoreGioco)$
	    +inizializzaMappa(mappa : Mappa) int[][]$
	    +generaPercorso(mappa : Mappa, posInizio : int[], posFine : int[])$
	    +generaCelleCasuali(mappa : Mappa)$
    }

    class Creabile {
    }

    class Maneba {
	    +attacca()
    }

    class Guardia {
	    +attacca()
    }

    class Trotur {
	    +attacca()
    }

    class Logger {
	    -textArea : JTextArea $
	    +Logger(textArea : JTextArea)$
	    +scriviMesaggio(msg : String)$
    }

    class Giocabile {
	    -agilita : int
	    -vita : int
	    -danno : int
	    -sprite : ImageIcon
	    -nome : String
	    +Giocabile(nome : String, path : String)
	    +attacca()*
	    +schiva() boolean
	    +getDanno() int
	    +getAgilita() int
	    +getVita() int
	    +getSprite() ImageIcon
	    +guadagnaVita(guadagno : int)
	    +perdiVita(perdita : int)
	    +controllaMorte() boolean
	    +consumaOggetto(oggetto : OggettoConsumabile)
    }

    class GestoreCreabili{
        -creabili : LinkedHashMap~String, ArrayList~Creabile~~ $
		-listaProbabilita : ArrayList~Integer~ $
		-totaleProbabilita : int $
        +aggiungiCreabile(creabile : Creabile)$
		+aggiungiProbabilita(probabilita : Integer) $
        +getCreabile(id : String) Creabile $
		+getRandomIdCreabile(probabilita : boolean) String $
		+getIdCreabileProbabile() String $
		+getIdCreabileRandom() String $	
    }
	
	class GestoreFile{
		+leggiCreabili()$
		+leggiGiocatori()$
		+leggiOggetti()$
	}
	
	class FormScelta{
	
	}

	<<abstract>> Oggetto
	<<abstract>> Giocatore
	<<enum>> TipoOggettoEquipaggiabile
	<<enum>> TipoOggettoConsumabile
	<<abstract>> Nemico
	<<enum>> TipoCella
	<<interface>> Creabile
	<<abstract>> Giocabile

	FormScelta --|> JFrame
    Oggetto<|--OggettoEquipaggiabile
	Oggetto<|--OggettoConsumabile
	Giocatore <|-- Mercenario
    Giocatore <|-- Cavaliere
    Giocatore <|-- Necromante
    Giocatore <|-- Vichingo
    Giocatore <|-- Moonless
    Giocatore <|-- Girl
    Giocatore <|-- Demonchild
    Giocatore --|> Giocabile
    Creabile <|-- Oggetto
    Party "1" --> "1" Inventario : -inventario
	Inventario "1" --> "n" Oggetto : -oggetti
    GestoreGioco "1" --> "1" Party : -party
    Party "1" --> "1...4" Giocabile : -personaggi
    GestoreInput "1" --> "1" Party : -party
    GestoreInput "1" --> "1" GestoreGioco : -gestoreGioco
    GestoreInput "1" --> "1" GestoreCombattimento : -gestoreCombattimento
    GestoreCombattimento "1" <--> "1" GestoreGioco : -gestoreCombattimento
    GestoreGioco "1" --> "1" Mappa : -mappa
    Giocatore "1" --> "1" OggettoEquipaggiabile : -oggettoDifensivo
    Giocatore "1" --> "1" OggettoEquipaggiabile : -oggettoOffensivo
    GeneratoreMappa "1" ..> "1" Mappa
    Mappa "1" *-- "n" Cella : -celle
    Nemico ..|> Creabile
    Maneba --|> Nemico
    Guardia --|> Nemico
    Trotur --|> Nemico
    GestoreGioco "1" --> "1" Creabile : -creabileCella
    Nemico --|> Giocabile
    Giocabile <--> GestoreGioco